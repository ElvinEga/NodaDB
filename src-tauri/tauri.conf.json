{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NodaDB",
  "version": "0.1.8",
  "identifier": "com.elvinega.nodadb",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NodaDB",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "acceptFirstMouse": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main window capabilities",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "core:window:allow-set-background-color",
            "dialog:allow-open",
            "dialog:allow-save",
            "dialog:allow-message",
            "dialog:allow-ask",
            "dialog:allow-confirm",
            "core:window:default",
            "core:window:allow-start-dragging",
            "core:window:allow-close",
            "core:window:allow-minimize",
            "core:window:allow-toggle-maximize",
            "core:window:allow-is-maximized",
            "process:default",
            "updater:default"
          ]
        }
      ]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/Assets.car"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      },
      "allowDowngrades": true
    },
    "resources": [],
    "category": "Productivity",
    "shortDescription": "A modern database management desktop application",
    "longDescription": "A modern, cross-platform database management tool.",
    "publisher": "Elvin Ega",
    "homepage": "https://github.com/ElvinEga/NodaDB",
    "copyright": "Copyright \u00a9 2026 Elvin Ega"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE2OTAzM0NENzMxREMxMEEKUldRS3dSMXp6VE9RcG9BVEl0eDJPMHVCTVZ2cG1xN1hpTlpHSjRzMHFET3g2NEkwckpmbDdoVFYK",
      "endpoints": [
        "https://github.com/ElvinEga/NodaDB/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
